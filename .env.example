# Application
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-XX:+UseG1GC -XX:InitialRAMPercentage=20.0 -XX:MaxRAMPercentage=70.0 -XX:MaxGCPauseMillis=200 -XX:+ExitOnOutOfMemoryError
APP_TMPFS_SIZE=64m
APP_PIDS_LIMIT=256
APP_MEM_LIMIT=768m
APP_MEM_RESERVATION=512m
APP_CPUS_LIMIT=1.0

# PostgreSQL
POSTGRES_DB=chitragupta
POSTGRES_USER=chitragupta
POSTGRES_PASSWORD=chitragupta_dev_password
POSTGRES_PORT=5432
POSTGRES_PIDS_LIMIT=256
POSTGRES_MEM_LIMIT=512m
POSTGRES_MEM_RESERVATION=256m
POSTGRES_CPUS_LIMIT=1.0
